========================================================================
Inline annotation completion
========================================================================
@inline<caret>
fun foo() {}
------------------------------------------------------------------------
@inline<caret>
fun foo() {}

========================================================================
Inline ref annotation completion
========================================================================
@inline_ref<caret>
fun foo() {}
------------------------------------------------------------------------
@inline_ref<caret>
fun foo() {}

========================================================================
Deprecated annotation completion
========================================================================
@depreca<caret>
fun foo() {}
------------------------------------------------------------------------
@deprecated("<caret>")
fun foo() {}

========================================================================
Overflow annotation completion
========================================================================
@overfl<caret>
struct Message {}
------------------------------------------------------------------------
@overflow1023_policy("suppress<caret>")
struct Message {}

========================================================================
No inline annotation completion
========================================================================
@noinli<caret>
fun foo() {}
------------------------------------------------------------------------
@noinline<caret>
fun foo() {}

========================================================================
No bounced annotation completion
========================================================================
@on_bounced_po<caret>
fun onBouncedMessage() {}
------------------------------------------------------------------------
@on_bounced_policy("manual<caret>")
fun onBouncedMessage() {}

========================================================================
Method ID annotation completion
========================================================================
@method<caret>
get fun foo() {}
------------------------------------------------------------------------
@method_id(0x1<caret>)
get fun foo() {}

========================================================================
Custom annotation completion
========================================================================
@custo<caret>
get fun foo() {}
------------------------------------------------------------------------
@custom(<caret>)
get fun foo() {}

========================================================================
Struct ABI annotation completion
========================================================================
@abi.min<caret>
struct Message {}
------------------------------------------------------------------------
@abi.minimalMsgValue(<caret>)
struct Message {}

========================================================================
Struct field ABI annotation completion
========================================================================
struct Message {
    @abi.client<caret>
    body: cell
}
------------------------------------------------------------------------
struct Message {
    @abi.clientType(<caret>)
    body: cell
}

========================================================================
Struct field nested ABI annotation completion
========================================================================
struct Message {
    @abi.<caret>
    body: cell
}
------------------------------------------------------------------------
struct Message {
    @abi.clientType(<caret>)
    body: cell
}

========================================================================
Test fail with annotation completion
========================================================================
@test.fail<caret>
get fun foo() {}
------------------------------------------------------------------------
@test.fail_with(<caret>)
get fun foo() {}
